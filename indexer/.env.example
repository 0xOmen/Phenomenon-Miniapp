# Copy from project root .env or set here. Ponder reads from indexer/ when running from indexer/.
# Base Sepolia RPC (required for indexer)
PONDER_RPC_URL_84532=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Or use same as root:
# ALCHEMY_BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Contract addresses (optional; defaults in ponder.config.ts)
# PHENOMENON_ADDRESS=0x47e7517c0641e00b06429eaedc4fdd331ba2df13
# GAMEPLAY_ENGINE_ADDRESS=0xEebf282F9BC6388924A2F66A478EC2Abd0ECFad4
# TICKET_ENGINE_ADDRESS=0x04964cdc1a4cb24a1b1212cdbada8a84eeb6388b
# PHENOMENON_START_BLOCK=38444062

# Required for "ponder start" (and when using Postgres). Max 45 chars.
DATABASE_SCHEMA=ponder

# Optional: PostgreSQL (avoids "PGlite is closed" on dev reload; use for production too)
# Local example: postgresql://postgres:postgres@127.0.0.1:5432/ponder
# PONDER_DATABASE_URL=postgresql://...
